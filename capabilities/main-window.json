{
  "$schema": "../tauri-capability.schema.json",
  "identifier": "main-window",
  "description": "Grants access to core events, dialog, and filesystem for the main window",
  "windows": ["main"],
  "permissions": [
    "core:event:allow-listen",
    "core:event:allow-emit",
    "dialog:allow-open",
    "fs:allow-read",
    "fs:allow-read-dir",
    "fs:allow-write",
    "fs:allow-read-file"
  ]
}


